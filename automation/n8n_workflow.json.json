        "jsCode": "// 1. Güncel tarih ve saati Türkiye saatine göre al\nlet tarih = new Date().toLocaleString(\"tr-TR\", { timeZone: \"Europe/Istanbul\" });\n\n// 2. Önceki JSON Çevirici düğümündeki verileri güvenle çek\nlet veri = $('JSON Çevirici (Code)').first().json;\nlet ip = veri.ipAddress || \"Bilinmiyor\";\nlet konum = veri.countryCode || \"Bilinmiyor\";\nlet risk = veri.abuseConfidenceScore || 0;\n\n// 3. Log metnini oluştur (Sondaki \\r\\n kodu alt satıra geçmesini sağlar)\nlet logMetni = `[${tarih}] 🛑 MANUEL ENGELLENDİ | IP: ${ip} | Konum: ${konum} | Risk: ${risk}/100\\r\\n`;\n\n// 4. SİHİRLİ KISIM: Metni n8n'in istediği o \"Binary\" (Dosya) formatına çevir\n$input.item.binary = {\n    data: {\n        data: Buffer.from(logMetni).toString('base64'),\n        mimeType: 'text/plain',\n        fileName: 'log.txt'\n    }\n};\n\nreturn $input.item;"
