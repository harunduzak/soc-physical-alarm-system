      "parameters": {
        "jsCode": "let responseData = $input.item.json.output;\n\n// 1. İHTİMAL: Yapay zeka bize zaten tertemiz bir Obje (JSON) gönderdiyse\nif (typeof responseData === 'object') {\n    return responseData;\n}\n\n// 2. İHTİMAL: Yapay zeka bize metin gönderdiyse (gevezelik yapsa bile)\nif (typeof responseData === 'string') {\n    try {\n        // SİHİRLİ KISIM: Metnin içindeki süslü parantezleri { ... } cımbızla çeker.\n        // Yapay zeka başına \"According to\" veya sonuna \"İşte sonuçlar\" yazsa bile onları yoksayar.\n        let jsonMatch = responseData.match(/\\{[\\s\\S]*\\}/);\n        \n        if (jsonMatch) {\n            return JSON.parse(jsonMatch[0]);\n        } else {\n            // Süslü parantez bulamazsa standart çevirmeyi dener\n            return JSON.parse(responseData);\n        }\n    } catch (error) {\n        // ÇÖKMEYİ ENGELLE: Herhangi bir hata olursa sistemi durdurma, sahte veriyle devam et.\n        return { \n            ipAddress: \"Ceviri Hatasi\", \n            countryCode: \"Bilinmiyor\", \n            abuseConfidenceScore: 0 \n        };\n    }\n}\n\n// Ne olur ne olmaz, sistem çökmesin diye varsayılan bir çıkış\nreturn { ipAddress: \"Bulunamadı\", countryCode: \"Bilinmiyor\", abuseConfidenceScore: 0 };"
      },
